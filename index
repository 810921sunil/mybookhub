  document.getElementById('form-modal-body').innerHTML=`
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Book Title *</label>
        <input class="form-input" id="f-title" placeholder="Enter book title" value="${b?b.title:''}"/>
      </div>
      <div class="form-group">
        <label class="form-label">Author Name *</label>
        <input class="form-input" id="f-author" placeholder="Author's full name" value="${b?b.author:''}"/>
      </div>
      <div class="form-group">
        <label class="form-label">Category</label>
        <select class="form-select" id="f-cat">
          ${CATEGORIES.filter(c=>c!=="All").map(c=>`<option ${b&&b.category===c?'selected':''}>${c}</option>`).join('')}
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Number of Pages</label>
        <input class="form-input" id="f-pages" type="number" placeholder="e.g. 320" value="${b?b.pages:200}"/>
      </div>
      <div class="form-group full">
        <label class="form-label">Description</label>
        <textarea class="form-input form-textarea" id="f-desc" placeholder="Write a compelling description…">${b?b.description:''}</textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Pricing</label>
        <select class="form-select" id="f-free" onchange="togglePriceField()">
          <option value="1" ${b&&b.isFree?'selected':''}>Free</option>
          <option value="0" ${b&&!b.isFree?'selected':''}>Paid</option>
        </select>
      </div>
      <div class="form-group" id="f-price-group" style="${b&&!b.isFree?'':'display:none'}">
        <label class="form-label">Price (USD)</label>
        <input class="form-input" id="f-price" type="number" step=".01" placeholder="9.99" value="${b&&b.price?b.price:''}"/>
      </div>
      <div class="form-group">
        <label class="form-label">Status</label>
        <select class="form-select" id="f-status">
          <option value="published" ${!b||b.status==='published'?'selected':''}>Published</option>
          <option value="unpublished" ${b&&b.status==='unpublished'?'selected':''}>Draft / Unpublished</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Cover Color Theme</label>
        <select class="form-select" id="f-color">
          ${COVER_COLORS.map((c,i)=>`<option value="${i}" ${b&&b.color===i?'selected':''}>Theme ${i+1}</option>`).join('')}
        </select>
      </div>
      <div class="form-group full">
        <label class="form-label">Book Cover Image</label>
        <div class="upload-zone" onclick="toast('File upload coming soon!','📁')">
          <div class="upload-zone-icon">🖼️</div>
          <div class="upload-zone-txt">Click to upload cover (JPEG, PNG)<br/><small>Recommended: 400×600px</small></div>
        </div>
      </div>
      <div class="form-group full">
        <label class="form-label">Book File (PDF / EPUB)</label>
        <div class="upload-zone" onclick="toast('File upload coming soon!','📄')">
          <div class="upload-zone-icon">📄</div>
          <div class="upload-zone-txt">Click to upload book file<br/><small>Supports PDF, EPUB — max 50MB</small></div>
        </div>
      </div>
    </div>
    <div class="form-actions-row">
      <button class="btn-cancel-form" onclick="closeModal('form-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveBookForm()">${b?'💾 Save Changes':'🚀 Publish Book'}</button>
    </div>`;

  openModal('form-modal');
}

function togglePriceField(){
  const isFree = document.getElementById('f-free').value==="1";
  document.getElementById('f-price-group').style.display = isFree?'none':'';
}

function saveBookForm(){
  const title = document.getElementById('f-title').value.trim();
  const author = document.getElementById('f-author').value.trim();
  if(!title||!author){ toast("Title and Author are required!","⚠️"); return; }

  const newData = {
    title, author,
    category: document.getElementById('f-cat').value,
    description: document.getElementById('f-desc').value.trim(),
    pages: parseInt(document.getElementById('f-pages').value)||200,
    isFree: document.getElementById('f-free').value==="1",
    price: parseFloat(document.getElementById('f-price')?.value)||0,
    status: document.getElementById('f-status').value,
    color: parseInt(document.getElementById('f-color').value)||0,
  };

  if(editingBookId){
    const b=books.find(x=>x.id===editingBookId);
    Object.assign(b,newData);
    toast("Book updated successfully! ✅","✅");
  } else {
    books.unshift({...newData,id:Date.now(),downloads:0,views:0,rating:0,reviews:[],isFeatured:false,published:new Date().toISOString().split('T')[0]});
    toast("Book published! 🚀","🚀");
  }
  closeModal('form-modal');
  renderAdminTable();
}

// ═══════════════════════════════════
// MOBILE NAV
// ═══════════════════════════════════
function toggleMobileNav(){
  const links = document.getElementById('nav-links');
  links.style.display = links.style.display==='flex'?'none':'flex';
  links.style.flexDirection='column';
  links.style.position='absolute';
  links.style.top='66px';
  links.style.left='0';
  links.style.right='0';
  links.style.background='rgba(17,13,7,.98)';
  links.style.padding='1rem';
  links.style.zIndex='400';
}

// ═══════════════════════════════════
// KEYBOARD
// ═══════════════════════════════════
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    closeModal('book-modal');
    closeModal('form-modal');
    closeViewer();
  }
});

// ═══════════════════════════════════
// INIT
// ═══════════════════════════════════
renderFeatured();
renderCatPills();
renderBooks();
</script>
</body>
</html>
