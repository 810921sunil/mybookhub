<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="description" content="MyBookHub — Your premier digital book publishing platform. Discover, read and download thousands of books."/>
<title>MyBookHub — Digital Publishing Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
/* ═══════════════════════════════════════════
   RESET & VARIABLES
═══════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#110d07;
  --ink-soft:#2c2016;
  --parchment:#faf5ec;
  --cream:#f2e8d5;
  --cream2:#ede0c8;
  --amber:#b8731a;
  --amber2:#d4892a;
  --amber3:#f0a93a;
  --amber-pale:#fdf0d8;
  --gold:#c9a227;
  --teal:#1a5c5a;
  --teal2:#237a77;
  --rust:#b83a1a;
  --slate:#2a3d4a;
  --slate2:#3d5566;
  --white:#ffffff;
  --shadow1:0 2px 8px rgba(17,13,7,.07);
  --shadow2:0 8px 28px rgba(17,13,7,.11);
  --shadow3:0 20px 60px rgba(17,13,7,.16);
  --r:10px;
  --r2:18px;
  --trans:.25s cubic-bezier(.4,0,.2,1);
}
html{scroll-behavior:smooth}
body{font-family:'Jost',sans-serif;background:var(--parchment);color:var(--ink);overflow-x:hidden;line-height:1.6}
img{max-width:100%;display:block}
button{font-family:'Jost',sans-serif;cursor:pointer}
input,select,textarea{font-family:'Jost',sans-serif}
h1,h2,h3,h4,h5{font-family:'Cormorant Garamond',serif;line-height:1.15}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--cream)}
::-webkit-scrollbar-thumb{background:var(--amber);border-radius:3px}

/* ═══════════════════════════════════════════
   UTILITY
═══════════════════════════════════════════ */
.hidden{display:none!important}
.page{display:none}
.page.active{display:block}
.container{max-width:1260px;margin:0 auto;padding:0 2rem}

/* ═══════════════════════════════════════════
   ANIMATIONS
═══════════════════════════════════════════ */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scaleIn{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
@keyframes float{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-10px) rotate(-3deg)}}
@keyframes float2{0%,100%{transform:translateY(0) rotate(4deg)}50%{transform:translateY(-8px) rotate(4deg)}}
@keyframes float3{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-12px) rotate(1deg)}}
@keyframes shimmer{0%,100%{opacity:.5}50%{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulseGold{0%,100%{box-shadow:0 0 0 0 rgba(201,162,39,.4)}70%{box-shadow:0 0 0 10px rgba(201,162,39,0)}}

.anim-fadeup{animation:fadeUp .55s ease both}
.anim-fadein{animation:fadeIn .4s ease both}
.anim-scalein{animation:scaleIn .35s ease both}
.d1{animation-delay:.1s}.d2{animation-delay:.2s}.d3{animation-delay:.3s}.d4{animation-delay:.4s}.d5{animation-delay:.5s}.d6{animation-delay:.6s}

/* ═══════════════════════════════════════════
   NAVBAR
═══════════════════════════════════════════ */
#navbar{
  position:sticky;top:0;z-index:500;
  background:rgba(17,13,7,.96);
  backdrop-filter:blur(14px);
  border-bottom:1px solid rgba(184,115,26,.18);
}
.nav-inner{
  display:flex;align-items:center;justify-content:space-between;
  height:66px;max-width:1260px;margin:0 auto;padding:0 2rem;gap:1rem;
}
.nav-brand{display:flex;align-items:center;gap:.7rem;cursor:pointer;text-decoration:none}
.nav-brand-icon{
  width:38px;height:38px;border-radius:8px;
  background:linear-gradient(135deg,var(--amber2),var(--amber));
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;flex-shrink:0;
}
.nav-brand-name{
  font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:700;
  color:var(--parchment);letter-spacing:-.3px;
}
.nav-brand-name span{color:var(--amber3)}
.nav-links{display:flex;align-items:center;gap:.1rem}
.nav-link{
  padding:.45rem .9rem;color:rgba(250,245,236,.65);font-size:.875rem;
  font-weight:500;background:none;border:none;border-radius:6px;
  transition:all var(--trans);white-space:nowrap;
}
.nav-link:hover,.nav-link.active{color:var(--parchment);background:rgba(184,115,26,.14)}
.nav-link.active{color:var(--amber3)}
.nav-actions{display:flex;align-items:center;gap:.6rem}
.nav-btn{
  padding:.48rem 1.15rem;border-radius:7px;font-size:.86rem;font-weight:600;
  border:none;transition:all var(--trans);
}
.nav-btn-ghost{
  background:transparent;color:rgba(250,245,236,.75);
  border:1.5px solid rgba(250,245,236,.18);
}
.nav-btn-ghost:hover{color:var(--parchment);border-color:rgba(184,115,26,.5);background:rgba(184,115,26,.1)}
.nav-btn-solid{
  background:linear-gradient(135deg,var(--amber2),var(--amber));
  color:var(--white);
}
.nav-btn-solid:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(184,115,26,.45)}
.nav-menu-toggle{display:none;background:none;border:none;color:var(--parchment);font-size:1.4rem;padding:.3rem}

/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
#hero{
  background:linear-gradient(160deg,#0e0904 0%,#1c1208 45%,#1a2016 100%);
  min-height:88vh;display:flex;align-items:center;position:relative;overflow:hidden;
  padding:5rem 0 4rem;
}
.hero-bg-mesh{
  position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 70% 60% at 15% 55%,rgba(184,115,26,.09) 0%,transparent 60%),
    radial-gradient(ellipse 50% 50% at 85% 25%,rgba(26,92,90,.12) 0%,transparent 55%),
    radial-gradient(ellipse 40% 40% at 60% 80%,rgba(184,115,26,.06) 0%,transparent 50%);
}
.hero-grid-lines{
  position:absolute;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(184,115,26,.035) 1px,transparent 1px),
    linear-gradient(90deg,rgba(184,115,26,.035) 1px,transparent 1px);
  background-size:64px 64px;
}
.hero-inner{
  position:relative;z-index:2;
  display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:.55rem;
  padding:.38rem 1rem;margin-bottom:1.6rem;
  background:rgba(184,115,26,.1);border:1px solid rgba(184,115,26,.22);
  border-radius:100px;color:var(--amber3);font-size:.78rem;font-weight:600;
  letter-spacing:.1em;text-transform:uppercase;
}
.hero-eyebrow::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--amber3);animation:shimmer 2s ease-in-out infinite}
.hero-h1{
  font-size:clamp(3rem,5.5vw,4.8rem);color:var(--parchment);
  margin-bottom:1.4rem;font-weight:700;
}
.hero-h1 em{font-style:italic;color:var(--amber3)}
.hero-p{
  font-size:1.1rem;color:rgba(250,245,236,.58);line-height:1.75;
  max-width:480px;margin-bottom:2.5rem;font-weight:300;
}
.hero-cta{display:flex;gap:.9rem;flex-wrap:wrap;margin-bottom:3.5rem}
.btn-hero-primary{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.9rem 2.1rem;background:linear-gradient(135deg,var(--amber2),var(--amber));
  color:var(--white);border:none;border-radius:9px;font-size:.95rem;font-weight:600;
  transition:all var(--trans);letter-spacing:.01em;
}
.btn-hero-primary:hover{transform:translateY(-2px);box-shadow:0 8px 26px rgba(184,115,26,.45)}
.btn-hero-ghost{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.9rem 2.1rem;background:transparent;
  color:rgba(250,245,236,.8);border:1.5px solid rgba(250,245,236,.2);
  border-radius:9px;font-size:.95rem;font-weight:600;transition:all var(--trans);
}
.btn-hero-ghost:hover{border-color:var(--amber2);color:var(--amber3)}
.hero-stats{display:flex;gap:2.5rem}
.hero-stat-num{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;color:var(--amber3);line-height:1}
.hero-stat-lbl{font-size:.78rem;color:rgba(250,245,236,.45);margin-top:.25rem;letter-spacing:.06em;text-transform:uppercase}

/* Book tower visual */
.hero-visual{position:relative;height:520px;display:flex;align-items:center;justify-content:center}
.book-tower{position:relative;width:260px;height:400px}
.book3d{
  position:absolute;border-radius:6px;
  box-shadow:-6px 6px 30px rgba(0,0,0,.6),4px 0 0 rgba(255,255,255,.05) inset;
}
.book3d-spine{position:absolute;left:0;top:0;width:14px;height:100%;background:rgba(0,0,0,.3);border-radius:3px 0 0 3px}
.book3d:nth-child(1){width:180px;height:260px;top:100px;left:20px;background:linear-gradient(135deg,#6b2d0a,#c45a1a);animation:float 7s ease-in-out infinite}
.book3d:nth-child(2){width:180px;height:260px;top:75px;left:45px;background:linear-gradient(135deg,#0a3d2d,#1a6a4a);animation:float2 6s ease-in-out infinite 1.5s}
.book3d:nth-child(3){
  width:185px;height:265px;top:50px;left:68px;
  background:linear-gradient(135deg,#1a2d5a,#2a4a8a);
  animation:float3 8s ease-in-out infinite .7s;
  display:flex;align-items:center;justify-content:center;
}
.book3d-title{padding:1rem;text-align:center;font-family:'Cormorant Garamond',serif;color:rgba(255,255,255,.9);font-size:.9rem;font-style:italic;line-height:1.4}
.hero-glow{position:absolute;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(184,115,26,.12) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.hero-badge{
  position:absolute;bottom:60px;right:-20px;
  width:90px;height:90px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--amber2));
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  box-shadow:0 8px 24px rgba(201,162,39,.4);animation:pulseGold 2.5s ease-in-out infinite;
}
.hero-badge-num{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;color:var(--white);line-height:1}
.hero-badge-lbl{font-size:.55rem;font-weight:600;color:rgba(255,255,255,.8);text-transform:uppercase;letter-spacing:.06em}

/* ═══════════════════════════════════════════
   STATS STRIP
═══════════════════════════════════════════ */
#stats-strip{background:var(--white);border-bottom:1px solid var(--cream2)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr)}
.stat-cell{
  padding:1.7rem 1rem;text-align:center;
  border-right:1px solid var(--cream2);
}
.stat-cell:last-child{border-right:none}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:2.1rem;font-weight:700;color:var(--amber);line-height:1}
.stat-lbl{font-size:.8rem;color:var(--slate2);margin-top:.3rem;letter-spacing:.04em}

/* ═══════════════════════════════════════════
   SEARCH BAR
═══════════════════════════════════════════ */
#search-section{padding:2.5rem 0 0}
.search-wrap{
  background:var(--white);border-radius:14px;
  box-shadow:var(--shadow3);overflow:hidden;
  display:flex;border:2px solid var(--cream2);
  transition:border-color var(--trans);
}
.search-wrap:focus-within{border-color:var(--amber)}
.search-icon{padding:0 1.2rem;font-size:1.1rem;display:flex;align-items:center;color:var(--amber)}
.search-input{
  flex:1;padding:1.05rem .5rem;border:none;outline:none;
  font-size:1rem;color:var(--ink);background:transparent;font-weight:400;
}
.search-input::placeholder{color:rgba(42,61,74,.4)}
.search-divider{width:1px;background:var(--cream2);margin:.6rem 0}
.search-select{
  padding:.5rem 1.3rem;border:none;outline:none;background:transparent;
  font-size:.875rem;color:var(--slate);cursor:pointer;min-width:148px;font-weight:500;
}
.search-btn{
  padding:0 2.2rem;background:linear-gradient(135deg,var(--amber2),var(--amber));
  color:var(--white);border:none;font-size:.9rem;font-weight:600;
  display:flex;align-items:center;gap:.45rem;transition:all var(--trans);
}
.search-btn:hover{background:linear-gradient(135deg,var(--amber3),var(--amber2))}

/* ═══════════════════════════════════════════
   SECTIONS
═══════════════════════════════════════════ */
.section{padding:4rem 0}
.section-top{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.2rem}
.section-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--amber);margin-bottom:.5rem}
.section-h2{font-size:clamp(1.7rem,3vw,2.4rem);color:var(--ink)}
.section-h2 span{color:var(--amber)}
.section-sub{font-size:.92rem;color:var(--slate2);margin-top:.35rem}
.see-all{
  background:none;border:1.5px solid var(--cream2);color:var(--slate2);
  padding:.48rem 1.2rem;border-radius:7px;font-size:.85rem;font-weight:600;
  transition:all var(--trans);white-space:nowrap;flex-shrink:0;
}
.see-all:hover{border-color:var(--amber);color:var(--amber);background:var(--amber-pale)}

/* ═══════════════════════════════════════════
   CATEGORY PILLS
═══════════════════════════════════════════ */
.cat-pills{display:flex;flex-wrap:wrap;gap:.6rem;margin-bottom:2.5rem}
.cat-pill{
  padding:.48rem 1.15rem;border-radius:100px;border:1.5px solid var(--cream2);
  background:var(--white);color:var(--slate);font-size:.84rem;font-weight:500;
  cursor:pointer;transition:all var(--trans);display:flex;align-items:center;gap:.35rem;
}
.cat-pill:hover{border-color:var(--amber2);color:var(--amber);transform:translateY(-1px)}
.cat-pill.active{background:var(--amber);border-color:var(--amber);color:var(--white);transform:translateY(-1px);box-shadow:0 4px 14px rgba(184,115,26,.3)}

/* ═══════════════════════════════════════════
   BOOK GRID & CARDS
═══════════════════════════════════════════ */
.books-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(196px,1fr));gap:1.6rem}
.book-card{
  background:var(--white);border-radius:var(--r2);overflow:hidden;
  box-shadow:var(--shadow1);transition:all var(--trans);cursor:pointer;position:relative;
}
.book-card:hover{transform:translateY(-7px);box-shadow:var(--shadow3)}
.book-card:hover .bc-overlay{opacity:1}

.bc-cover{height:238px;position:relative;overflow:hidden}
.bc-cover-img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.book-card:hover .bc-cover-img{transform:scale(1.04)}

.bc-overlay{
  position:absolute;inset:0;background:rgba(17,13,7,.62);
  opacity:0;transition:opacity var(--trans);
  display:flex;align-items:center;justify-content:center;gap:.6rem;
}
.bc-overlay-btn{
  padding:.5rem 1.05rem;border-radius:7px;font-size:.8rem;font-weight:700;
  border:none;cursor:pointer;transition:transform .15s;
}
.bc-overlay-btn:hover{transform:scale(1.06)}
.bc-btn-read{background:var(--amber2);color:var(--white)}
.bc-btn-save{background:rgba(255,255,255,.16);color:var(--white);border:1px solid rgba(255,255,255,.3)!important}

.bc-badge{
  position:absolute;top:.7rem;left:.7rem;
  padding:.22rem .62rem;border-radius:100px;
  font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;
}
.badge-new{background:var(--teal);color:var(--white)}
.badge-hot{background:var(--rust);color:var(--white)}
.badge-free{background:var(--teal2);color:var(--white)}
.badge-paid{background:var(--slate);color:var(--white)}
.badge-feat{background:var(--gold);color:var(--ink)}

.bc-info{padding:.95rem 1.1rem 1.15rem}
.bc-cat{font-size:.72rem;font-weight:700;color:var(--amber);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.35rem}
.bc-title{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:600;color:var(--ink);line-height:1.3;margin-bottom:.28rem}
.bc-author{font-size:.82rem;color:var(--slate2)}
.bc-meta{display:flex;align-items:center;justify-content:space-between;margin-top:.7rem}
.bc-stars{color:var(--gold);font-size:.75rem;letter-spacing:1px}
.bc-rating{font-size:.82rem;color:var(--slate2);display:flex;align-items:center;gap:.3rem}
.bc-dl{font-size:.75rem;color:var(--slate2)}

/* Empty state */
.empty-state{text-align:center;padding:5rem 1rem;color:var(--slate2)}
.empty-state-icon{font-size:3.5rem;margin-bottom:1rem;opacity:.5}
.empty-state h3{font-size:1.4rem;color:var(--ink);margin-bottom:.5rem}

/* ═══════════════════════════════════════════
   FEATURED BOOK STRIP
═══════════════════════════════════════════ */
#featured-strip{
  background:linear-gradient(135deg,#0e0904 0%,#1a140a 50%,#0e1a0e 100%);
  padding:5rem 0;position:relative;overflow:hidden;
}
#featured-strip::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 60% 80% at 20% 50%,rgba(184,115,26,.07),transparent 60%);
}
.featured-book{display:grid;grid-template-columns:280px 1fr;gap:3.5rem;align-items:center;position:relative;z-index:1}
.featured-cover{
  height:390px;border-radius:12px;overflow:hidden;
  box-shadow:-10px 10px 40px rgba(0,0,0,.6),8px -4px 0 var(--amber);
  position:relative;flex-shrink:0;
}
.featured-tag{
  display:inline-block;padding:.32rem .9rem;background:var(--gold);
  color:var(--ink);border-radius:100px;font-size:.75rem;font-weight:700;
  text-transform:uppercase;letter-spacing:.07em;margin-bottom:1.1rem;
}
.featured-title{font-size:clamp(2rem,4vw,3rem);color:var(--parchment);margin-bottom:.6rem}
.featured-author{font-size:1rem;color:rgba(250,245,236,.55);margin-bottom:1.1rem}
.featured-desc{font-size:.93rem;color:rgba(250,245,236,.62);line-height:1.75;max-width:520px;margin-bottom:2rem;font-weight:300}
.featured-actions{display:flex;gap:.9rem;flex-wrap:wrap;align-items:center}
.featured-rating{display:flex;align-items:center;gap:.6rem;margin-left:auto}
.featured-rating .stars{color:var(--gold);font-size:.9rem}
.featured-rating span{color:rgba(250,245,236,.5);font-size:.85rem}

/* ═══════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════ */
.btn{display:inline-flex;align-items:center;gap:.45rem;font-weight:600;border:none;border-radius:8px;transition:all var(--trans);cursor:pointer;font-family:'Jost',sans-serif}
.btn-primary{padding:.78rem 1.8rem;background:linear-gradient(135deg,var(--amber2),var(--amber));color:var(--white);font-size:.92rem}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(184,115,26,.4)}
.btn-secondary{padding:.78rem 1.8rem;background:var(--teal);color:var(--white);font-size:.92rem}
.btn-secondary:hover{background:var(--teal2);transform:translateY(-1px)}
.btn-outline{padding:.78rem 1.6rem;background:transparent;color:rgba(250,245,236,.8);border:1.5px solid rgba(250,245,236,.22);font-size:.92rem}
.btn-outline:hover{border-color:var(--amber2);color:var(--amber3)}
.btn-sm{padding:.52rem 1.1rem;font-size:.83rem;border-radius:7px}
.btn-icon{padding:.6rem;border-radius:7px;background:var(--cream);color:var(--slate);border:none}
.btn-icon:hover{background:var(--cream2);color:var(--amber)}

/* ═══════════════════════════════════════════
   MODAL
═══════════════════════════════════════════ */
.modal-overlay{
  position:fixed;inset:0;z-index:800;
  background:rgba(17,13,7,.78);backdrop-filter:blur(7px);
  display:none;align-items:center;justify-content:center;padding:1rem;
}
.modal-overlay.open{display:flex;animation:fadeIn .22s ease}
.modal{
  background:var(--white);border-radius:22px;width:100%;max-width:920px;
  max-height:92vh;overflow-y:auto;animation:scaleIn .3s ease;
}
.modal-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.4rem 2rem;border-bottom:1px solid var(--cream);position:sticky;top:0;
  background:var(--white);z-index:2;
}
.modal-head h3{font-size:1.15rem}
.modal-close{
  width:34px;height:34px;border-radius:50%;background:var(--cream);
  border:none;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;
  transition:all var(--trans);
}
.modal-close:hover{background:var(--amber);color:var(--white)}
.modal-body{display:grid;grid-template-columns:230px 1fr;gap:2.2rem;padding:2rem}
.modal-cover-wrap{height:320px;border-radius:12px;overflow:hidden;box-shadow:var(--shadow2)}
.modal-info{}
