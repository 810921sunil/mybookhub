function toggleFav(id){
  if(favorites.includes(id)){
    favorites = favorites.filter(f=>f!==id);
    toast("Removed from saved books");
  } else {
    favorites.push(id);
    toast("Saved to your library ♥", "♥");
  }
  // update button in modal if open
  const btn = document.getElementById('fav-btn-'+id);
  if(btn) btn.textContent = favorites.includes(id)?'♥':'♡';
  renderBooks();
}

function dlBook(id){
  const b = books.find(x=>x.id===id);
  if(!b) return;
  b.downloads++;
  downloadHistory.unshift({id, date:"Today"});
  toast(`Downloading "${b.title}"… 📥`, "📥");
  if(selectedBookId===id) renderBooks();
}

