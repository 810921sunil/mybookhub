const CATEGORIES = ["All","Fiction","Non-Fiction","Science","History","Technology","Business","Philosophy","Poetry","Children","Self-Help","Biography","Mystery","Romance","Fantasy","Science Fiction"];

// ═══════════════════════════════════
// COVER GENERATOR
// ═══════════════════════════════════
function genCover(book, h="100%"){
  return `<div class="gen-cover" style="background:${COVER_COLORS[book.color||0]};height:${h}">
    <div class="gen-cover-spine"></div>
    <div class="gen-cover-content">
      <div class="gen-cover-deco"></div>
      <div class="gen-cover-cat">${book.category}</div>
