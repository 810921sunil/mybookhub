function openViewer(id){
  const b = books.find(x=>x.id===id);
  if(!b) return;
  closeModal('book-modal');

  viewerPages = [
    {title:"Chapter One: The Beginning",
     html:`<h2>Chapter One: The Beginning</h2>
     <p class="drop-cap">Welcome to <strong>${b.title}</strong> by <em>${b.author}</em>. This is a preview of the full edition available on MyBookHub.</p>
     <p>The story opens on a crisp autumn morning — the kind that makes you feel anything is possible. The protagonist stands at the edge of a decision that will change everything, a fork in the road that countless others had faced before, yet none had felt quite so personal as this moment right now.</p>
     <p>It had been three years since the last time anything truly remarkable happened. Three years of ordinary days stacked one upon another like pages in a book no one particularly wanted to read. But today was different. Today, the world seemed to hold its breath in anticipation.</p>
     <p>She walked across the cobblestones slowly, deliberately, letting each step be its own small act of intention. The city was waking around her — the smell of fresh bread, the distant rumble of trams, a child's laughter somewhere above.</p>`},
    {title:"Chapter Two: The Discovery",
     html:`<h2>Chapter Two: The Discovery</h2>
     <p class="drop-cap">As the morning unfolded, a discovery emerged that would set the entire course of the narrative. Details came slowly, like a photograph developing in a darkroom, each new piece altering the picture that had seemed so clear just moments before.</p>
     <p>"What we know," said the wise old scholar, adjusting his spectacles, "is merely the surface of what is true. The depths remain hidden until we are ready to receive them."</p>
     <p>And so the journey truly began — not with a dramatic leap, but with a single careful step forward into the unknown territory of possibility.</p>
     <p>The letter was sealed with red wax. On it, an insignia she'd seen once before, in her grandmother's old photographs, in a box she'd been told never to open. She opened it now.</p>`},
    {title:"Chapter Three: The Journey",
     html:`<h2>Chapter Three: The Journey</h2>
     <p class="drop-cap">The road ahead was uncertain, as all truly worthwhile roads must be. She carried with her only the essentials — a journal, a compass that pointed not north but toward something more mysterious, and the letter.</p>
     <p>At each crossroads she paused, not from indecision but from respect for the weight of the moment. Every choice shapes the person we become. Every path not taken whispers quietly in our dreams.</p>
     <p>By nightfall she had reached the edge of the forest. The trees stood tall and ancient, their canopy filtering starlight into silver threads. Somewhere deep within, a light flickered.</p>
     <p><em>Continue reading in the full edition — available for download above.</em></p>`}
  ];

  viewerCurrentPage = 0;
  document.getElementById('viewer-title').textContent = b.title;
  renderViewerPage();
  document.getElementById('pdf-viewer').classList.add('open');
  document.body.style.overflow='hidden';
}

function renderViewerPage(){
  const p = viewerPages[viewerCurrentPage];
  document.getElementById('viewer-content').innerHTML = `<div class="viewer-page">${p.html}</div>
    <div style="display:flex;gap:.75rem;padding:.5rem 0">
      ${viewerPages.map((_,i)=>`<button class="viewer-ctrl-btn" onclick="viewerGoPage(${i})" style="${i===viewerCurrentPage?'background:var(--amber);color:var(--white);border-color:var(--amber)':''}">Chapter ${i+1}</button>`).join('')}
    </div>`;
  document.getElementById('viewer-page-info').textContent = `${viewerCurrentPage+1} / ${viewerPages.length}`;
  document.getElementById('viewer-prev').disabled = viewerCurrentPage===0;
  document.getElementById('viewer-next').disabled = viewerCurrentPage===viewerPages.length-1;
}

function viewerPage(d){ viewerGoPage(viewerCurrentPage+d); }
function viewerGoPage(i){
  viewerCurrentPage = Math.max(0,Math.min(viewerPages.length-1,i));
  renderViewerPage();
  document.getElementById('viewer-content').scrollTop=0;
}
function closeViewer(){
  document.getElementById('pdf-viewer').classList.remove('open');
  document.body.style.overflow='';
}

