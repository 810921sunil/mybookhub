    showAdminLogin();
  } else {
    adminTab('overview', document.querySelector('.admin-nav-btn.active'));
  }
}

// ═══════════════════════════════════
// TOAST
// ═══════════════════════════════════
let toastTimer;
function toast(msg, icon="📚"){
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  document.getElementById('toast-icon').textContent = icon;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), 3200);
}

// ═══════════════════════════════════
// MODAL
// ═══════════════════════════════════
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }

// ═══════════════════════════════════
// FEATURED BOOK
// ═══════════════════════════════════
function renderFeatured(){
  const book = books.find(b=>b.isFeatured && b.status==="published");
  if(!book){ document.getElementById('featured-strip').style.display='none'; return; }
  document.getElementById('featured-strip').style.display='';
  const stars = "★".repeat(Math.floor(book.rating))+"☆".repeat(5-Math.floor(book.rating));
  document.getElementById('featured-book').innerHTML = `
    <div class="featured-cover anim-fadeup">${genCover(book,"100%")}</div>
    <div class="anim-fadeup d2">
      <div class="featured-tag">⭐ Featured Book</div>
      <h2 class="featured-title">${book.title}</h2>
      <p class="featured-author">by ${book.author} &nbsp;·&nbsp; ${book.category}</p>
      <p class="featured-desc">${book.description}</p>
      <div class="featured-actions">
        <button class="btn btn-primary" onclick="openBookModal(${book.id})">Read Preview →</button>
        <button class="btn btn-outline" onclick="dlBook(${book.id})">${book.isFree?'📥 Download Free':'Buy $'+book.price}</button>
        <div class="featured-rating">
          <span class="stars">${stars}</span>
          <span>${book.rating} · ${(book.downloads/1000).toFixed(1)}k downloads</span>
        </div>
      </div>
    </div>
  `;
  document.getElementById('hero-book-title').textContent = book.title;
}

// ═══════════════════════════════════
// CATEGORY PILLS
// ═══════════════════════════════════
function renderCatPills(){
  const wrap = document.getElementById('cat-pills');
  wrap.innerHTML = CATEGORIES.map(c=>`
    <button class="cat-pill ${activeCategory===c?'active':''}" onclick="filterCat('${c}')">${c}</button>
  `).join('');
}

function filterCat(cat){
  activeCategory = cat;
  document.getElementById('search-cat').value = cat==="All"?"":cat;
  renderCatPills();
  renderBooks();
}

// ═══════════════════════════════════
// BOOKS GRID
// ═══════════════════════════════════
function renderBooks(){
  renderCatPills();
  const q = (document.getElementById('search-input')?.value||"").toLowerCase();
  const selCat = document.getElementById('search-cat')?.value||"";
  const cat = selCat || (activeCategory==="All"?"":activeCategory);

  const filtered = books.filter(b=>{
    if(b.status!=="published") return false;
    if(cat && b.category!==cat) return false;
    if(q && !b.title.toLowerCase().includes(q) && !b.author.toLowerCase().includes(q) && !b.category.toLowerCase().includes(q)) return false;
    return true;
  });

  const lbl = document.getElementById('books-count-label');
  if(lbl) lbl.textContent = `${filtered.length} book${filtered.length!==1?'s':''} found`;

  const grid = document.getElementById('books-grid');
  if(!grid) return;

  if(filtered.length===0){
    grid.innerHTML=`<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-state-icon">📭</div>
      <h3>No books found</h3>
      <p>Try adjusting your search or category.</p>
    </div>`;
    return;
  }

  grid.innerHTML = filtered.map((b,i)=>{
    const isFav = favorites.includes(b.id);
    const badge = b.isFeatured?'<span class="bc-badge badge-feat">⭐ Featured</span>':
                  b.downloads>15000?'<span class="bc-badge badge-hot">🔥 Hot</span>':
                  b.isFree?'<span class="bc-badge badge-free">Free</span>':'';
    const ratingStars = "★".repeat(Math.floor(b.rating));
    return `<div class="book-card anim-fadeup" style="animation-delay:${i*0.045}s" onclick="openBookModal(${b.id})">
      <div class="bc-cover">
        ${genCover(b,"100%")}
        ${badge}
        <div class="bc-overlay">
          <button class="bc-overlay-btn bc-btn-read" onclick="event.stopPropagation();openBookModal(${b.id})">Read</button>
          <button class="bc-overlay-btn bc-btn-save" onclick="event.stopPropagation();toggleFav(${b.id})">${isFav?'♥':'♡'} Save</button>
        </div>
      </div>
      <div class="bc-info">
        <div class="bc-cat">${b.category}</div>
        <div class="bc-title">${b.title}</div>
        <div class="bc-author">by ${b.author}</div>
        <div class="bc-meta">
          <div class="bc-rating"><span class="bc-stars">${ratingStars}</span> ${b.rating}</div>
