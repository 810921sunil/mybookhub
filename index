function openBookModal(id){
  const b = books.find(x=>x.id===id);
  if(!b) return;
  selectedBookId = id;
  b.views++;

  const isFav = favorites.includes(id);
  const stars = "★".repeat(Math.floor(b.rating))+"☆".repeat(5-Math.floor(b.rating));

  document.getElementById('modal-body').innerHTML = `
    <div class="modal-cover-wrap">${genCover(b,"100%")}</div>
    <div class="modal-info">
      <div class="modal-cat">${b.category}</div>
      <h2 class="modal-title">${b.title}</h2>
      <p class="modal-author">by ${b.author}</p>
      <div class="modal-rating-row">
        <span style="color:var(--gold);font-size:.95rem">${stars}</span>
        <b>${b.rating}</b>
        <span style="color:var(--slate2);font-size:.83rem">(${b.reviews.length} reviews)</span>
        <span style="color:var(--slate2);font-size:.82rem;margin-left:auto">${(b.views/1000).toFixed(1)}k views</span>
      </div>
      <p class="modal-desc">${b.description}</p>
      <div class="modal-actions">
        <button class="btn btn-primary" onclick="openViewer(${id})">📖 Read Online</button>
        <button class="btn btn-secondary" onclick="dlBook(${id})">${b.isFree?'📥 Download Free':'💳 Buy $'+b.price}</button>
        <button class="btn btn-sm btn-icon" id="fav-btn-${id}" onclick="toggleFav(${id})" title="Save">${isFav?'♥':'♡'}</button>
      </div>
      <div class="modal-details-grid">
        ${[["Pages",b.pages],["Published",b.published?.split('-')[0]||'N/A'],["Category",b.category],["Price",b.isFree?"Free":"$"+b.price]].map(([l,v])=>`
          <div class="detail-item"><div class="lbl">${l}</div><div class="val">${v}</div></div>`).join('')}
      </div>
    </div>`;

  renderModalReviews(id);
  openModal('book-modal');
}

function renderModalReviews(id){
  const b = books.find(x=>x.id===id);
  if(!b) return;
  reviewStarSelected = 5;
  document.getElementById('modal-reviews').innerHTML = `
    <h4>Reviews & Ratings</h4>
    <div class="review-input-row">
      <div class="star-pick" id="star-pick">
        ${[1,2,3,4,5].map(s=>`<button class="star-pick-btn ${s<=reviewStarSelected?'on':''}" onclick="setReviewStar(${s},${id})" data-s="${s}">★</button>`).join('')}
      </div>
      <input class="review-txt-input" id="review-input" placeholder="Share your thoughts…" onkeydown="if(event.key==='Enter')postReview(${id})"/>
      <button class="review-post-btn" onclick="postReview(${id})">Post</button>
    </div>
    ${b.reviews.map(r=>`
      <div class="review-card">
        <div class="review-card-top">
          <div class="rv-avatar">${r.u[0]}</div>
          <div><div class="rv-name">${r.u}</div><div class="rv-stars">${"★".repeat(r.r)}</div></div>
          <div class="rv-date">${r.d}</div>
        </div>
        <div class="rv-text">${r.t}</div>
      </div>`).join('')}
  `;
}

function setReviewStar(s, bookId){
  reviewStarSelected = s;
  document.querySelectorAll('#star-pick .star-pick-btn').forEach((btn,i)=>{
    btn.classList.toggle('on', i<s);
  });
}

function postReview(id){
  const inp = document.getElementById('review-input');
  const txt = inp.value.trim();
  if(!txt) return;
  const b = books.find(x=>x.id===id);
  const user = userLoggedIn ? userName : "Guest";
  b.reviews.unshift({u:user, r:reviewStarSelected, t:txt, d:"Today"});
  // recalc rating
  b.rating = parseFloat(((b.reviews.reduce((s,r)=>s+r.r,0)/b.reviews.length)||b.rating).toFixed(1));
  inp.value="";
  renderModalReviews(id);
  toast("Review posted! ⭐");
}

