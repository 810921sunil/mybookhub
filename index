    </div>
  </div>`;
}

// ═══════════════════════════════════
// PAGE ROUTING
// ═══════════════════════════════════
function goPage(page){
  // hide all
  document.querySelectorAll('.page').forEach(p=>p.style.display='none');
  document.getElementById('page-admin').style.display='none';
  document.getElementById('page-admin').classList.remove('active');
  document.getElementById('navbar').style.display='';

  if(page==='home'){
    document.getElementById('page-home').style.display='block';
    renderFeatured();
    renderBooks();
  } else if(page==='auth'){
    document.getElementById('page-auth').style.display='block';
  } else if(page==='udash'){
    document.getElementById('page-udash').style.display='block';
    renderUserDash();
  }
}

function goAdmin(){
  document.querySelectorAll('.page').forEach(p=>p.style.display='none');
  document.getElementById('navbar').style.display='none';
